{
  "name": "markdown-it-variables",
  "version": "1.1.1",
  "description": "Use text/link/abbreviations variables in your markdown files",
  "keywords": [
    "abbreviations",
    "markdown",
    "markdown-it",
    "markdown-it-plugin",
    "technical writing",
    "tokens",
    "variables"
  ],
  "homepage": "https://github.com/Dschungelabenteuer/markdown-it-variables/tree/main/#readme",
  "bugs": {
    "url": "https://github.com/Dschungelabenteuer/markdown-it-variables/issues"
  },
  "license": "MIT",
  "author": "Charles Gruenais",
  "repository": {
    "type": "git",
    "url": "https://github.com/Dschungelabenteuer/markdown-it-variables",
    "directory": "packages/core"
  },
  "files": [
    "dist"
  ],
  "type": "module",
  "main": "./dist/index.js",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "require": "./dist/index.cjs",
      "import": "./dist/index.js"
    }
  },
  "publishConfig": {
    "types": "./dist/index.d.ts"
  },
  "scripts": {
    "build": "tsdown",
    "lint": "oxlint .",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "format": "oxfmt --write",
    "check": "pnpm format && pnpm lint && pnpm test",
    "changeset:release": "pnpm build && changeset publish",
    "changeset:version": "changeset version && pnpm install --lockfile-only"
  },
  "devDependencies": {
    "@changesets/changelog-github": "^0.7.0",
    "@changesets/cli": "^2.31.1",
    "@types/markdown-it": "^14.1.2",
    "markdown-it": "^14.3.0",
    "oxfmt": "^0.59.0",
    "oxlint": "^1.74.0",
    "tsdown": "^0.22.13",
    "typescript": "^7.0.2",
    "vitest": "^4.1.10"
  },
  "peerDependencies": {
    "markdown-it": "^13.0.1"
  }
}
